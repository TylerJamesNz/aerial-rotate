<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aerialrotate</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/usr/local/bin/aerial-rotate.sh</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>/usr/local/var/aerial-rotate/trigger</string>
    </array>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/var/log/aerial-rotate.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/aerial-rotate.log</string>
</dict>
</plist>
